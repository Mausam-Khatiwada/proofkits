# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Dodo Payments
DODO_PAYMENTS_API_KEY=your_dodo_api_key
DODO_PAYMENTS_WEBHOOK_KEY=whsec_your_webhook_secret
DODO_PRODUCT_ID_PRO=your_dodo_product_id
# DODO_PAYMENTS_BASE_URL=https://test.dodopayments.com
# DODO_PAYMENTS_ENVIRONMENT=test

# Resend
RESEND_API_KEY=your_resend_api_key

# Groq
GROQ_API_KEY=your_groq_api_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: distributed rate limiting (recommended in production)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Optional: security hardening
AUDIT_LOG_SALT=your_random_salt_32_chars
CSP_REPORT_ONLY=true
CSP_REPORT_URI=

# Outbox worker
OUTBOX_WORKER_KEY=your_random_secret_openssl_rand_base64_32
OUTBOX_ALLOW_VERCEL_CRON=false